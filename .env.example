# Jack AI — Environment Template
# Copy this to .env and add your keys

SECRET_KEY=super-secret-jack-key-change-me

# LLM Providers
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

LLM_PROVIDER=groq

# Web Research
TAVILY_API_KEY=

# Database
# Leave DATABASE_URL empty for local SQLite, or add your Supabase link for Cloud
DATABASE_URL=
SQLITE_DB_PATH=./data/jack.db

# UI / Voice
TTS_VOICE=en-IN-NeerjaNeural
